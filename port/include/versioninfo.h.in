#ifndef _IN_VERSIONINFO_H
#define _IN_VERSIONINFO_H

/* Build environment */
#define VERSION_TARGET "@VERSION_TARGET@"
#define VERSION_ARCH "@VERSION_ARCH@"
#define VERSION_ROMID "@VERSION_ROMID@"
#define VERSION_BUILD "@VERSION_BUILD@"
#define VERSION_HASH "@VERSION_HASH@"
#define VERSION_BRANCH "@VERSION_BRANCH@"

/* Semantic version (D13 Update System) */
#define VERSION_MAJOR @VERSION_SEM_MAJOR@
#define VERSION_MINOR @VERSION_SEM_MINOR@
#define VERSION_PATCH @VERSION_SEM_PATCH@
#define VERSION_DEV @VERSION_SEM_DEV@

#endif
